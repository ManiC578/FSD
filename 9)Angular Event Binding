#app.html
<h2>Event Binding Example</h2>

<button (click)="showMessage()">
    Click Me
</button>

<p>{{ message }}</p>

#app.ts
import { Component } from '@angular/core';

@Component({
  selector: 'app-root',
  templateUrl: './app.html',
  styleUrl: './app.css'
})
export class App {

  message = "";

  showMessage() {
    this.message = "Button Clicked!";
  }

}
