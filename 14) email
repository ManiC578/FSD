import React from "react";

function App() {

  function checkEmail() {
    let email = document.getElementById("email").value;

    if (email.includes("@") && email.includes(".")) {
      alert("Valid Email");
    } else {
      alert("Invalid Email");
    }
  }

  return (
    <div>
      <h2>Email Validation Form</h2>

      <input
        type="text"
        id="email"
        placeholder="Enter Email"
      />

      <button onClick={checkEmail}>
        Check Email
      </button>
    </div>
  );
}

export default App;
